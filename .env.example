# 실제 값은 여기에 넣지 마세요. .env 파일에만 저장하세요.
# 공통: <ENV>_HOST, <ENV>_PORT, <ENV>_USER, <ENV>_PASSWORD, <ENV>_DATABASE
# 옵션: <ENV>_DRIVER (기본: ODBC Driver 18 for SQL Server)
#
# ODBC 로그인 타임아웃(초). VPN·원격 DB에서 HYT00 이 나오면 90~120 등으로 늘려 보세요.
# DBGIT_ODBC_LOGIN_TIMEOUT_SEC=60
#
# 객체 검색 시 SQL `TOP (n)` 상한(기본 100000, 최대 500000). 화면 500건 제한과 별개입니다.
# DBGIT_OBJECT_SEARCH_SQL_CAP=100000

PRD_HOST=10.0.0.1
PRD_PORT=11433
PRD_USER=your_user
PRD_PASSWORD=your_password
PRD_DATABASE=your_db

STG_HOST=10.0.0.2
STG_PORT=21433
STG_USER=your_user
STG_PASSWORD=your_password
STG_DATABASE=your_db

DEV_HOST=10.0.0.3
DEV_PORT=11433
DEV_USER=your_user
DEV_PASSWORD=your_password
DEV_DATABASE=your_db

QA_HOST=10.0.0.4
QA_PORT=11433
QA_USER=your_user
QA_PASSWORD=your_password
QA_DATABASE=your_db
